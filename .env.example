# Database (split config; Prisma uses DATABASE_URL composed from these)
DB_HOST=localhost
DB_PORT=3306
DB_USER=epoch
DB_PASSWORD=epoch_secret
DB_NAME=epoch_judge
# API / Judge 启动时自动 prisma migrate deploy（false 关闭）
DB_AUTO_MIGRATE=true
# Optional: override composed URL entirely
# DATABASE_URL=mysql://epoch:epoch_secret@localhost:3306/epoch_judge

# Redis（分项配置；.env 放在仓库根目录，yarn dev:api 会自动加载）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=epoch_redis_secret
REDIS_KEY_PREFIX=epoch-judge
# REDIS_DB=0
# 若设置 REDIS_URL，将优先于上面分项（勿与 REDIS_HOST 混用指向不同地址）
# REDIS_URL=redis://:epoch_redis_secret@localhost:6379

# API
API_PORT=3000
# CORS 允许的源（逗号分隔 URL）；开发环境默认允许 http://localhost:8080，生产环境需显式配置
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Bcrypt 哈希轮数（比赛密码、用户密码等）
BCRYPT_ROUNDS=10

# Rate Limiting（@nestjs/throttler，全局默认 60 次/分钟）
THROTTLE_ENABLED=true
THROTTLE_TTL=60
THROTTLE_LIMIT=60
THROTTLE_AUTH_LIMIT=5
THROTTLE_SUBMISSION_LIMIT=10
# 多实例部署时设为 redis 以共享限流计数（需安装 @nest-lab/throttler-storage-redis）
THROTTLE_STORAGE=memory
# nginx 反向代理后信任 X-Forwarded-For 的跳数（false 关闭）
TRUST_PROXY=1

# Storage (default: local)
STORAGE_TYPE=local
STORAGE_LOCAL_ROOT=./data/testcases

# S3 (when STORAGE_TYPE=s3)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PREFIX=testcases
S3_REGION=us-east-1

# Judge
JUDGE_WORKER_CONCURRENCY=2
JUDGE_GLOBAL_MAX_INFLIGHT=10
JUDGE_GRPC_PORT=50051
JUDGE_MOCK=false
# API 启动时自动恢复非终态提交入队
JUDGE_RECOVER_ON_STARTUP=true

# Web (dev proxy target)
WEB_PORT=8080

# Seed admin (deploy script)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_EMAIL=admin@epoch.local
