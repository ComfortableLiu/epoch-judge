generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  PROBLEM_EDITOR
}

enum ProblemVisibility {
  PUBLIC
  PRIVATE
}

enum JudgeMode {
  OI
  ACM
}

enum Language {
  JAVASCRIPT
  C
  CPP
  PYTHON
  JAVA
}

enum SubmissionStatus {
  PENDING
  QUEUED
  JUDGING
  COMPILING
  RUNNING
  REJUDGE_QUEUED
  REJUDGING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILE_ERROR
  SECURITY_ERROR
  SYSTEM_ERROR
}

enum TestcaseVerdict {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILE_ERROR
  SKIPPED
}

enum ContestVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id                 String     @id @default(cuid())
  username           String     @unique
  email              String?    @unique
  passwordHash       String     @map("password_hash")
  displayName        String?    @map("display_name")
  role               Role       @default(USER)
  preferredLanguage  Language?  @map("preferred_language")
  preferredJudgeMode JudgeMode? @map("preferred_judge_mode")
  mustResetPassword  Boolean    @default(false) @map("must_reset_password")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  submissions           Submission[]
  contestRegistrations  ContestRegistration[]
  createdProblems       Problem[]             @relation("ProblemCreator")
  createdContests       Contest[]             @relation("ContestCreator")

  @@map("users")
}

model Problem {
  id               String            @id @default(cuid())
  number           Int               @unique @default(autoincrement())
  title            String
  statement        String            @db.Text
  difficulty       Int               @default(1)
  visibility       ProblemVisibility @default(PRIVATE)
  createdById      String?           @map("created_by_id")
  timeLimitMs      Int               @default(1000) @map("time_limit_ms")
  memoryLimitKb    Int               @default(262144) @map("memory_limit_kb")
  tags             Json              @default("[]")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  createdBy        User?             @relation("ProblemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  testcases        ProblemTestcase[]
  assets           ProblemAsset[]
  submissions      Submission[]
  contestProblems  ContestProblem[]

  @@map("problems")
}

model ProblemAsset {
  id         String   @id @default(cuid())
  problemId  String   @map("problem_id")
  path       String
  storageKey String   @map("storage_key")
  mimeType   String   @map("mime_type")
  size       Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, path])
  @@map("problem_assets")
}

model ProblemTestcase {
  id         String   @id @default(cuid())
  problemId  String   @map("problem_id")
  ordinal    Int
  inputKey   String   @map("input_key")
  outputKey  String   @map("output_key")
  inputSize  Int      @default(0) @map("input_size")
  outputSize Int      @default(0) @map("output_size")
  checksum   String?
  score      Int      @default(0)
  isSample   Boolean  @default(false) @map("is_sample")
  createdAt  DateTime @default(now()) @map("created_at")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  results SubmissionTestcaseResult[]

  @@unique([problemId, ordinal])
  @@map("problem_testcases")
}

model Submission {
  id         String           @id @default(cuid())
  number     Int              @unique @default(autoincrement())
  userId     String           @map("user_id")
  problemId  String           @map("problem_id")
  contestId  String?          @map("contest_id")
  language   Language
  judgeMode  JudgeMode        @map("judge_mode")
  sourceCode String           @map("source_code") @db.Text
  status          SubmissionStatus @default(PENDING)
  score           Int?
  timeMs          Int?             @map("time_ms")
  memoryKb        Int?             @map("memory_kb")
  rejudgeCount    Int              @default(0) @map("rejudge_count")
  lastRejudgedAt  DateTime?        @map("last_rejudged_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id])
  problem  Problem  @relation(fields: [problemId], references: [id])
  contest  Contest? @relation(fields: [contestId], references: [id])
  testcaseResults SubmissionTestcaseResult[]

  @@index([userId, createdAt])
  @@index([problemId, createdAt])
  @@map("submissions")
}

model SubmissionTestcaseResult {
  id           String          @id @default(cuid())
  submissionId String          @map("submission_id")
  testcaseId   String          @map("testcase_id")
  verdict      TestcaseVerdict @default(PENDING)
  score        Int             @default(0)
  timeMs       Int?            @map("time_ms")
  memoryKb     Int?            @map("memory_kb")
  message      String?         @db.Text

  submission Submission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testcase   ProblemTestcase @relation(fields: [testcaseId], references: [id])

  @@unique([submissionId, testcaseId])
  @@map("submission_testcase_results")
}

model Contest {
  id              String            @id @default(cuid())
  number          Int               @unique @default(autoincrement())
  title           String
  description     String            @db.Text
  visibility      ContestVisibility @default(PUBLIC)
  accessPassword  String?           @map("access_password")
  judgeMode       JudgeMode         @map("judge_mode")
  startAt         DateTime          @map("start_at")
  endAt           DateTime          @map("end_at")
  freezeAt        DateTime?         @map("freeze_at")
  createdById     String?           @map("created_by_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  createdBy     User?                 @relation("ContestCreator", fields: [createdById], references: [id], onDelete: SetNull)
  problems      ContestProblem[]
  registrations ContestRegistration[]
  submissions   Submission[]

  @@map("contests")
}

model ContestProblem {
  id        String @id @default(cuid())
  contestId String @map("contest_id")
  problemId String @map("problem_id")
  label     String
  ordinal   Int

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id])

  @@unique([contestId, problemId])
  @@map("contest_problems")
}

model ContestRegistration {
  id                  String   @id @default(cuid())
  contestId           String   @map("contest_id")
  userId              String   @map("user_id")
  passwordVerified    Boolean  @default(false) @map("password_verified")
  /// 报名时冻结的展示名（displayName 或 username），赛后不随用户资料变更
  displayNameSnapshot String   @map("display_name_snapshot")
  /// 打星队伍：榜单名前带 *，不计入官方排名与成绩
  isStarTeam          Boolean  @default(false) @map("is_star_team")
  createdAt           DateTime @default(now()) @map("created_at")

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([contestId, userId])
  @@map("contest_registrations")
}

model JudgeNode {
  id            String   @id @default(cuid())
  name          String
  host          String?
  lastHeartbeat DateTime @map("last_heartbeat")
  concurrency   Int      @default(1)
  isOnline      Boolean  @default(true) @map("is_online")

  @@map("judge_nodes")
}

model SystemConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
